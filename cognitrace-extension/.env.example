# CogniTrace extension runtime configuration
# Copy this file to ".env" when local secrets/config are needed.

# Optional backend signing API endpoint (used in future cloud-signing phase)
COGNITRACE_API_BASE_URL=

# Optional Sentry DSN for error reporting
COGNITRACE_SENTRY_DSN=

# Build stage marker: development | staging | production
COGNITRACE_STAGE=development
