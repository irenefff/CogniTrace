{
  "name": "cognitrace-extension",
  "displayName": "CogniTrace (智痕)",
  "version": "0.0.1",
  "description": "A Chrome extension for Proof-of-Process authorship verification.",
  "author": "CogniTrace Team",
  "license": "MIT",
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20.11.0 <21",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "tsc --noEmit",
    "check:env": "node ./scripts/check-env.mjs",
    "healthcheck": "npm run check:env && npm run lint && npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "ci:verify": "npm run check:env && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "clsx": "^2.1.0",
    "dexie": "^3.2.4",
    "dexie-react-hooks": "^1.1.7",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.309.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^2.10.4",
    "sharp": "^0.34.5",
    "svgo": "^3.3.2",
    "tailwind-merge": "^2.2.0",
    "uuid": "^13.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.17",
    "crypto-browserify": "^3.12.1",
    "plasmo": "^0.90.5",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://docs.google.com/*",
      "https://word.office.com/*",
      "https://*.officeapps.live.com/*"
    ],
    "permissions": [
      "storage",
      "tabs",
      "sidePanel"
    ]
  }
}
